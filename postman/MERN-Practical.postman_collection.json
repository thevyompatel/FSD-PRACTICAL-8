{
  "info": {
    "_postman_id": "f6df95c8-89b0-4ef3-b26c-4f429fb31dd5",
    "name": "MERN Practical - Auth Upload Payment",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Collection for JWT auth, image upload, products and mock payment flow"
  },
  "item": [
    {
      "name": "1. Register",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('Register success is true', function () {",
              "    pm.expect(json.success).to.eql(true);",
              "});",
              "",
              "if (json.data && (json.data.id || json.data._id)) {",
              "    pm.environment.set('userId', json.data.id || json.data._id);",
              "}",
              "",
              "if (json.token) {",
              "    pm.environment.set('token', json.token);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Postman User\",\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\",\n  \"phone\": \"9999999999\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "register"
          ]
        }
      }
    },
    {
      "name": "2. Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('Login returns token', function () {",
              "    pm.expect(json.token).to.be.a('string').and.not.empty;",
              "});",
              "",
              "pm.environment.set('token', json.token);",
              "if (json.data && (json.data.id || json.data._id)) {",
              "    pm.environment.set('userId', json.data.id || json.data._id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      }
    },
    {
      "name": "3. Auth Me",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/auth/me",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "me"
          ]
        }
      }
    },
    {
      "name": "4. Add Product (with image)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('Product create success true', function () {",
              "    pm.expect(json.success).to.eql(true);",
              "});",
              "",
              "if (json.data && json.data._id) {",
              "    pm.environment.set('productId', json.data._id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "name",
              "value": "Postman Practical Product",
              "type": "text"
            },
            {
              "key": "price",
              "value": "299.50",
              "type": "text"
            },
            {
              "key": "category",
              "value": "Demo",
              "type": "text"
            },
            {
              "key": "stock",
              "value": "3",
              "type": "text"
            },
            {
              "key": "description",
              "value": "Created from Postman collection",
              "type": "text"
            },
            {
              "key": "image",
              "type": "file",
              "src": ""
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/api/products",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "products"
          ]
        }
      }
    },
    {
      "name": "5. Get Products",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/products",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "products"
          ]
        }
      }
    },
    {
      "name": "6. Mock Payment",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('Payment status success', function () {",
              "    pm.expect(json.status).to.eql('success');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": 499.99\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/payment",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "payment"
          ]
        }
      }
    }
  ]
}
